# Required
ATLAS_GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override model (default: gemini-2.5-flash)
# ATLAS_MODEL=gemini-2.5-flash

# Optional: Voice interface (for real-time conversational mode)
# Speech-to-text (Deepgram recommended for best latency)
# ATLAS_DEEPGRAM_API_KEY=your-deepgram-api-key
# Text-to-speech (ElevenLabs recommended for best quality)
# ATLAS_ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Voice mode: push_to_talk (default) or continuous
# ATLAS_VOICE_MODE=push_to_talk

# Optional: Autonomy system
# ATLAS_AUTONOMY_ENABLED=true
# ATLAS_AUTONOMY_INTERVAL=30
# ATLAS_DEFAULT_MODE=assistive

# Optional: web search (SerpAPI or similar)
# SERP_API_KEY=...
